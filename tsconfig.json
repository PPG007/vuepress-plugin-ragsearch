{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "lib",
    "rootDir": "src",
    "declaration": true,
    "paths": {
      "@vuepress/client": ["./node_modules/vuepress/client"],
      "vue": ["./node_modules/vue"]
    }
  },
  "include": ["src"]
}
