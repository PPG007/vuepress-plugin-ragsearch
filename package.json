{
  "name": "vuepress-plugin-ragsearch",
  "version": "0.1.0",
  "description": "VuePress 2 plugin for RAG-powered documentation search and AI chat",
  "keywords": [
    "vuepress",
    "plugin",
    "rag",
    "search",
    "ai"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./lib/node/index.d.ts",
      "import": "./lib/node/index.js"
    },
    "./client": {
      "types": "./lib/client/config.d.ts",
      "import": "./lib/client/config.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-vue-sfc.mjs",
    "dev": "vuepress dev demo",
    "demo:build": "npm run build && vuepress build demo"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "vuepress": "^2.0.0-rc.0"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
    "@vuepress/bundler-vite": "2.0.0-rc.30",
    "@vuepress/client": "2.0.0-rc.30",
    "@vuepress/theme-default": "2.0.0-rc.130",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.8",
    "typescript": "^5.5.0",
    "vuepress": "2.0.0-rc.30"
  }
}
